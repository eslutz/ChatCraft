{
  "name": "chatcraft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tool-based 3MF project editor for conversational 3D printing workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eslutz/ChatCraft.git"
  },
  "bin": {
    "chatcraft": "./dist/cli.js",
    "chatcraft-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/cli.ts",
    "mcp": "tsx src/mcp/server.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "commander": "^12.1.0",
    "fast-xml-parser": "^5.9.3",
    "jszip": "^3.10.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.34",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
